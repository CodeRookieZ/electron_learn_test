{
  "name": "my-electron-app",
  "version": "1.0.0",
  "description": "learn",
  "keywords": [
    "electron"
  ],
  "homepage": "https://github.com/CodeRookieZ/electron_learn_test#readme",
  "bugs": {
    "url": "https://github.com/CodeRookieZ/electron_learn_test/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodeRookieZ/electron_learn_test.git"
  },
  "license": "ISC",
  "author": "JianChuanZhao",
  "type": "commonjs",
  "main": "src/main/main.js",
  "scripts": {
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "start": "electron-forge start",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "release": "electron-vite build && electron-builder --publish=always",
    "release:draft": "electron-vite build && electron-builder --publish=never"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "electron-vite": "^5.0.0",
    "install": "^0.13.0",
    "npm": "^11.14.1",
    "update-electron-app": "^3.2.0"
  }
}
